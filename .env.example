# .env.example
POSTGRES_PASSWORD=changeme

ANALYTICS_PIPELINES_DIR=/data/pipelines

# Analytics database (PostgreSQL)
ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASSWORD=changeme
# Read-only user for Lightdash and Vanna (SELECT only, no writes)
ANALYTICS_DB_READONLY_PASSWORD=changeme_readonly

# NOTE: ParadeDB upgrade path
# If query latency on GROUP BY / aggregations becomes noticeable (>500ms on >1M rows),
# swap the analytics-db image from postgres:15 to paradedb/paradedb — drop-in compatible,
# no dbt/Lightdash/Vanna changes required. Re-run dlt ingestion to reload data.

LIGHTDASH_SECRET=changeme
LIGHTDASH_EMAIL=admin@example.com
LIGHTDASH_PASSWORD=your_secure_password
# Set after first-boot manual registration (Settings → Personal Access Tokens)
LIGHTDASH_API_KEY=

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

DEEPSEEK_API_KEY=xxx
VANNA_MODEL=deepseek-chat
CHROMA_PATH=~/data/vanna-chroma
# Public URL of Lightdash — used as the iframe src in the chat widget
# Local: http://localhost:8080  |  VPS: https://your-lightdash.domain.com
LIGHTDASH_PUBLIC_URL=http://localhost:8080
